# Environment Variables for Simplified Travel AI Agent
# Copy this to .env and fill in your values

# LLM Configuration (OpenAI or Grok)
TRAVEL_LLM_BACKEND=openai
TRAVEL_LLM_MODEL=gpt-4o-mini
TRAVEL_LLM_BASE_URL=https://api.openai.com/v1
TRAVEL_LLM_API_KEY=your-openai-api-key-here

# Alternative: Use Grok (xAI)
# TRAVEL_LLM_BACKEND=openai
# TRAVEL_LLM_MODEL=grok-beta
# TRAVEL_LLM_BASE_URL=https://api.x.ai/v1
# TRAVEL_LLM_API_KEY=your-grok-api-key-here
